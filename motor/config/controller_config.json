{
  "logging_config": {
    "log_level": "INFO",
    "log_max_line_length": 8192,
    "log_file": null,
    "log_format": "%(levelname)s  %(asctime)s  [%(filename)s:%(lineno)d]  %(message)s",
    "log_date_format": "%Y-%m-%d %H:%M:%S"
  },

  "api_config": {
    "controller_api_host": "127.0.0.1",
    "controller_api_port": 57675,
    "coordinator_api_dns": "127.0.0.1",
    "coordinator_api_port": 1026
  },

  "tls_config": {
    "enable_tls": false,
    "ca_cert_path": "security/controller/cert/ca.crt",
    "cert_path": "security/controller/cert/server.crt",
    "key_path": "security/controller/keys/server.key"
  },

  "instance_config": {
    "instance_assemble_timeout": 600,
    "instance_assembler_check_internal": 1,
    "instance_assembler_cmd_send_internal": 1,
    "send_cmd_retry_times": 3,
    "instance_manager_check_internal": 1,
    "instance_heartbeat_timeout": 5,
    "instance_expired_timeout": 300
  },

  "event_config": {
    "event_consumer_sleep_interval": 1.0,
    "coordinator_heartbeat_interval": 0.5
  },

  "fault_tolerance_config": {
    "enable_fault_tolerance": true,
    "strategy_center_check_internal": 1,
    "enable_scale_p2d": true,
    "enable_lingqu_network_recover": true
  },

  "standby_config": {
    "enable_master_standby": false,
    "master_standby_check_interval": 5,
    "master_lock_ttl": 60,
    "master_lock_retry_interval": 5,
    "master_lock_max_failures": 3,
    "master_lock_key": "/controller/master_lock"
  },

  "etcd_config": {
    "etcd_host": "localhost",
    "etcd_port": 2379,
    "etcd_timeout": 5,
    "enable_etcd_persistence": false
  }
}