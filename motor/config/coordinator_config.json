{
    "prometheus_metrics_config": {
        "reuse_time": 3
    },
    "exception_config": {
        "max_retry": 5,
        "retry_delay": 0.2,
        "first_token_timeout": 600,
        "infer_timeout": 600
    },
    "scheduler_config": {
        "deploy_mode": "pd_separate",
        "scheduler_type": "load_balance"
    },
    "tls_config": {
        "request_server_tls_enable": true,
        "request_server_tls_items": {
            "ca_cert": "./security/request/security/certs/ca.pem",
            "tls_cert": "./security/request/security/certs/cert.pem",
            "tls_key": "./security/request/security/keys/cert.key.pem",
            "tls_passwd": "./security/request/security/pass/key_pwd.txt",
            "kmcKsfMaster": "./security/request/tools/pmt/master/ksfa",
            "kmcKsfStandby": "./security/request/tools/pmt/standby/ksfb",
            "tls_crl": ""
        }
    },
    "health_check_config": {
        "dummy_request_interval": 5.0,
        "max_consecutive_failures": 3,
        "dummy_request_timeout": 10.0,
        "controller_api_dns": "mindie-ms-controller-service.mindie.svc.cluster.local",
        "controller_api_port": 57675,
        "dummy_request_endpoint": "/v1/completions",
        "dummy_request_body": {
            "model": "test-model",
            "prompt": "Health check. Please respond with OK only.",
            "max_tokens": 3,
            "temperature": 0.1,
            "top_p": 0.9,
            "stream": false
        },
        "alarm_endpoint": "/v1/alarm/coordinator",
        "alarm_timeout": 5.0,
        "terminate_instance_endpoint": "/controller/terminate_instance",
        "thread_join_timeout": 5.0,
        "error_retry_interval": 1.0
    },
    "http_config": {
        "coordinator_api_dns": "motor-controller-service.mindie.svc.cluster.local",
        "combined_mode": false,
        "coordinator_api_host": "127.0.0.1",
        "coordinator_api_infer_port": 1025,
        "coordinator_api_mgmt_port": 1026
    },
    "api_key_config": {
        "enabled": true,
        "valid_keys": [
            "sk-test123456789",
            "sk-coordinator2024"
        ],
        "header_name": "Authorization",
        "key_prefix": "Bearer ",
        "skip_paths": [
            "/",
            "/startup",
            "/readiness",
            "/liveness",
            "/health",
            "/metrics",
            "/instances/refresh",
            "/docs",
            "/redoc",
            "/openapi.json",
            "/favicon.ico"
        ]
    },
    "rate_limit_config": {
        "enabled": true,
        "max_requests": 1000,
        "window_size": 60,
        "scope": "global",
        "skip_paths": [
            "/health",
            "/readiness",
            "/metrics",
            "/docs",
            "/redoc",
            "/openapi.json",
            "/favicon.ico",
            "/startup"
        ],
        "error_message": "too many requests, please try again later",
        "error_status_code": 429
    }
}
